<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        noupdate="1": la categoria e il gruppo vengono creati una volta sola
        durante l'installazione e non vengono sovrascritti dagli aggiornamenti
        successivi del modulo, preservando eventuali utenti assegnati.
    -->
    <data noupdate="1">
 
        <record id="module_category_building_pay" model="ir.module.category">
            <field name="name">BuildingPay</field>
            <field name="description">Gestione del servizio BuildingPay</field>
            <field name="sequence">100</field>
        </record>
 
        <record id="group_building_pay_manager" model="res.groups">
            <field name="name">Building Pay Manager</field>
            <field name="category_id" ref="module_category_building_pay"/>
            <field name="comment">
                Gli utenti con questo ruolo possono abilitare o disabilitare
                il servizio BuildingPay sugli indirizzi di fatturazione.
            </field>
        </record>
 
    </data>
</odoo>
 
