<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!--
        1. PROFILO PORTALE — aggiunge il blocco upload accordo contrattuale
           dopo la sezione dei dettagli personali.
    -->
    <template id="portal_my_details_building_pay"
              inherit_id="portal.portal_my_details"
              name="BuildingPay - Accordo nel profilo portale">

        <xpath expr="//div[hasclass('o_portal_details')]" position="after">
            <div id="building_pay_accordo_section" class="mt-4 p-3 border rounded bg-light">

                <h5 class="mb-3">
                    <i class="fa fa-file-signature me-2 text-primary"/>
                    Accordo contrattuale con Progetti e Soluzioni
                </h5>

                <t t-if="request.env.user.partner_id.x_building_pay_accordo">
                    <div class="alert alert-success mb-3" role="alert">
                        <i class="fa fa-check-circle me-2"/>
                        <strong>Accordo caricato.</strong>
                        <t t-if="request.env.user.partner_id.x_building_pay_accordo_filename">
                            File: <em><t t-esc="request.env.user.partner_id.x_building_pay_accordo_filename"/></em>.
                        </t>
                        Carica un nuovo file per sostituirlo.
                    </div>
                </t>
                <t t-else="">
                    <div class="alert alert-warning mb-3" role="alert">
                        <i class="fa fa-exclamation-triangle me-2"/>
                        <strong>Documento mancante.</strong>
                        È necessario caricare l'accordo per poter effettuare ordini.
                    </div>
                </t>

                <form method="post"
                      action="/building_pay/upload_accordo"
                      enctype="multipart/form-data"
                      class="row g-2 align-items-end">
                    <input type="hidden" name="csrf_token"
                           t-att-value="request.csrf_token()"/>
                    <div class="col flex-grow-1">
                        <label class="form-label fw-semibold" for="accordo_file_input">
                            Seleziona file (PDF, Word, immagine)
                        </label>
                        <input type="file"
                               id="accordo_file_input"
                               name="accordo_file"
                               class="form-control"
                               accept=".pdf,.doc,.docx,.png,.jpg,.jpeg"/>
                    </div>
                    <div class="col-auto">
                        <button type="submit" class="btn btn-primary">
                            <i class="fa fa-upload me-1"/>Carica
                        </button>
                    </div>
                </form>

            </div>
        </xpath>
    </template>


    <!--
        2. FORM INDIRIZZO PORTALE — aggiunge i campi BuildingPay
           (contratto, checkbox readonly, IBAN, stato abilitazione).
           Il form viene modificato per usare enctype multipart e
           il route BuildingPay che gestisce i file.
    -->
    <template id="portal_address_form_building_pay"
              inherit_id="portal.address_form"
              name="BuildingPay - Campi nel form modifica indirizzo">

        <!-- Aggiunge enctype e action BuildingPay al form -->
        <xpath expr="//form[hasclass('o_portal_address_form')]" position="attributes">
            <attribute name="enctype">multipart/form-data</attribute>
            <attribute name="action">/building_pay/save_address_and_redirect</attribute>
        </xpath>

        <!-- Aggiunge i campi BuildingPay prima della fine del form -->
        <xpath expr="//div[hasclass('o_portal_address_form')]" position="inside">
            <div id="building_pay_fields_section" class="mt-4 pt-3 border-top">

                <h6 class="fw-bold text-primary mb-3">
                    <i class="fa fa-building me-1"/>
                    Dati BuildingPay
                </h6>

                <div class="row g-3">

                    <!-- Contratto: upload + stato -->
                    <div class="col-12">
                        <label class="form-label fw-semibold">Contratto BuildingPay</label>
                        <t t-if="partner_id and partner_id.x_building_pay_contratto_caricato">
                            <div class="alert alert-success py-2 mb-2">
                                <i class="fa fa-check-circle me-1"/>
                                Contratto caricato
                                <t t-if="partner_id.x_building_pay_contratto_filename">
                                    : <em><t t-esc="partner_id.x_building_pay_contratto_filename"/></em>
                                </t>
                            </div>
                        </t>
                        <t t-else="">
                            <div class="alert alert-warning py-2 mb-2">
                                <i class="fa fa-exclamation-circle me-1"/>
                                Nessun contratto caricato.
                            </div>
                        </t>
                        <input type="file" name="contratto_file" class="form-control"
                               accept=".pdf,.doc,.docx,.png,.jpg,.jpeg"/>
                        <small class="text-muted">
                            Carica un file per aggiungere o sostituire il contratto.
                        </small>
                    </div>

                    <!-- Checkbox contratto caricato (readonly) -->
                    <div class="col-12">
                        <div class="form-check">
                            <input type="checkbox"
                                   class="form-check-input"
                                   id="chk_contratto_caricato"
                                   disabled="disabled"
                                   t-att-checked="partner_id.x_building_pay_contratto_caricato
                                                  if partner_id else False"/>
                            <label class="form-check-label text-muted"
                                   for="chk_contratto_caricato">
                                Contratto caricato
                                <small>(aggiornato automaticamente)</small>
                            </label>
                        </div>
                    </div>

                    <!-- IBAN -->
                    <div class="col-12 col-md-8">
                        <label class="form-label fw-semibold" for="building_pay_iban">
                            IBAN
                        </label>
                        <input type="text"
                               id="building_pay_iban"
                               name="building_pay_iban"
                               class="form-control"
                               placeholder="IT60 X054 2811 1010 0000 0123 456"
                               t-att-value="partner_id.x_building_pay_iban
                                            if partner_id else ''"/>
                        <small class="text-muted">
                            Verrà salvato nel conto corrente bancario del contatto.
                        </small>
                    </div>

                    <!-- Abilitazione BuildingPay — solo lettura per il portale -->
                    <div class="col-12">
                        <div class="form-check">
                            <input type="checkbox"
                                   class="form-check-input"
                                   id="chk_bp_abilitato"
                                   disabled="disabled"
                                   t-att-checked="partner_id.x_building_pay_abilitato
                                                  if partner_id else False"/>
                            <label class="form-check-label fw-semibold"
                                   for="chk_bp_abilitato">
                                Abilitato al servizio BuildingPay
                                <small class="text-muted fw-normal ms-1">
                                    (gestito dall'amministratore)
                                </small>
                            </label>
                        </div>
                    </div>

                </div><!-- /row -->
            </div>
        </xpath>

    </template>

</odoo>
